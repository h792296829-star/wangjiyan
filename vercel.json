{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "",
  "installCommand": "pip install -r requirements.txt",
  "framework": null,
  "functions": {
    "api/*.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "COZE_WORKSPACE_PATH": "/tmp"
  }
}
